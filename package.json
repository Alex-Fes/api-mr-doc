{
  "name": "dental-clinic-mail-server",
  "version": "1.0.0",
  "private": true,
  "description": "Mail backend for dental clinic website forms",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "start:dev": "node scripts/run-with-env.js .env.development node src/index.js",
    "start:stage": "node scripts/run-with-env.js .env.stage node src/index.js",
    "start:prod": "node scripts/run-with-env.js .env.production node src/index.js",
    "dev:env": "node scripts/run-with-env.js .env.development node --watch src/index.js",
    "test": "node --test"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.16"
  },
  "engines": {
    "node": ">=18"
  }
}
