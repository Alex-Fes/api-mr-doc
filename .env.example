PORT=3003
NODE_ENV=production
FRONTEND_URL=https://mr-doc.ru
API_URL=https://api.mr-doc.ru

# SMTP settings from your mailbox provider.
SMTP_HOST=smtp.timeweb.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@mr-doc.ru
SMTP_PASS=

# Email envelope and notification recipient.
MAIL_FROM=info@mr-doc.ru
MAIL_TO=info@mr-doc.ru

# Upload limits.
MAX_FILE_SIZE_MB=15
MAX_FILES=5

# Permanent local upload storage.
STORAGE_DIR=storage
