PORT=3001
NODE_ENV=production

# Frontend URL allowed to call this API.
# Example: https://example.ru
CORS_ORIGIN=http://localhost:3000

# SMTP settings from your mailbox provider.
SMTP_HOST=smtp.example.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=site@example.ru
SMTP_PASS=change-me

# Email envelope and notification recipient.
MAIL_FROM=site@example.ru
MAIL_TO=info@example.ru

# Upload limits.
MAX_FILE_SIZE_MB=15
MAX_FILES=5
