PORT=4000
NODE_ENV=production
FRONTEND_URL=https://mr-doc.univpro.ru
API_URL=https://api-mr-doc.univpro.ru

# SMTP settings from your mailbox provider.
SMTP_HOST=smtp.timeweb.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@mr-doc.univpro.ru
SMTP_PASS=

# Email envelope and notification recipient.
MAIL_FROM=info@mr-doc.univpro.ru
MAIL_TO=fes.custom@gmail.com

# Upload limits.
MAX_FILE_SIZE_MB=15
MAX_FILES=5

# Permanent local upload storage.
STORAGE_DIR=storage
